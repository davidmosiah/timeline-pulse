{
  "name": "timeline-pulse",
  "version": "0.1.1",
  "mcpName": "io.github.davidmosiah/timeline-pulse",
  "description": "MCP server + public atlas of timeline-shift folklore, Mandela Effect reports, and collider-era myth — every claim labeled, every source graded. A cultural archive, not a proof engine. Built while the LHC sleeps (LS3, 2026–2030).",
  "type": "module",
  "bin": {
    "timeline-pulse": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "start": "node dist/index.js",
    "validate": "node scripts/validate-data.mjs",
    "policy": "node scripts/check-policy.mjs",
    "sync-site": "node scripts/sync-site-data.mjs",
    "smoke": "node tests/smoke.test.mjs",
    "test": "npm run policy && npm run build && npm run validate && node scripts/sync-site-data.mjs --check && npm run smoke"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mandela-effect",
    "timeline",
    "cern",
    "lhc",
    "folklore",
    "mythology",
    "archive",
    "ai-agents",
    "claude"
  ],
  "author": "David Mosiah (@delx369)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidmosiah/timeline-pulse.git"
  },
  "homepage": "https://timeline-pulse.vercel.app",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4"
  }
}
